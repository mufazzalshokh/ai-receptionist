{
  "name": "ai-receptionist",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "AI Receptionist Platform — world-class AI-powered receptionist for businesses",
  "scripts": {
    "predev": "cp -f .env.local apps/web/.env.local 2>/dev/null || true",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:coverage": "turbo test -- --coverage",
    "test:db": "pnpm --filter @ai-receptionist/db test",
    "test:voice": "pnpm --filter @ai-receptionist/voice test",
    "db:generate": "pnpm --filter @ai-receptionist/db generate",
    "db:push": "pnpm --filter @ai-receptionist/db push",
    "db:migrate": "pnpm --filter @ai-receptionist/db migrate",
    "db:studio": "pnpm --filter @ai-receptionist/db studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "turbo": "^2.9.1",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "pino": "^9.14.0"
  }
}
