# ============================================
# AI Receptionist — Environment Variables
# Copy to .env.local and fill in your values
# ============================================

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# AI — Anthropic Claude
ANTHROPIC_API_KEY=""

# Voice — Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Voice Streaming Server (Fly.io)
VOICE_SERVER_URL=""  # e.g., "wss://ai-receptionist-voice.fly.dev"
VOICE_WS_SECRET=""   # Shared secret for voice WS auth
METRICS_SECRET=""    # Secret for /metrics endpoint auth

# Speech-to-Text — Deepgram
DEEPGRAM_API_KEY=""

# Text-to-Speech — ElevenLabs
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID_EN=""
ELEVENLABS_VOICE_ID_LV=""
ELEVENLABS_VOICE_ID_RU=""

# Text-to-Speech Fallback — Cartesia
CARTESIA_API_KEY=""

# Booking — Alteg (VividDerm)
ALTEG_API_KEY=""
ALTEG_COMPANY_ID="757934"

# Email — SendGrid / Resend
RESEND_API_KEY=""
ESCALATION_FROM_EMAIL="noreply@your-domain.com"

# Escalation Webhook (Slack, Zapier, etc.)
ESCALATION_WEBHOOK_URL=""  # e.g., "https://hooks.slack.com/services/..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WIDGET_URL="http://localhost:3001"

# CORS — comma-separated allowed origins for widget API (default: * for dev)
CORS_ALLOWED_ORIGINS="*"  # Production: "https://your-site.com,https://widget.your-site.com"

# Logging
LOG_LEVEL="debug"  # Production: "info"

# Auth (NextAuth v5 / Auth.js)
AUTH_SECRET=""       # Generate with: openssl rand -base64 32
AUTH_URL="http://localhost:3000"
